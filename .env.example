# Environment (dev/prod)
ENV=dev

# OpenRouter (chat LLM)
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
# Optional attribution headers for OpenRouter rankings
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=Veda Portfolio Bot

# Local dev / evals only: load the resume from a local PDF instead of R2.
# If unset and R2 is not configured, a *resume*.pdf next to rag_engine.py is used.
# LOCAL_RESUME_PDF=embeddings-resume-amit.pdf

# API Key for chat endpoint auth
API_KEY=your-api-key-here

# Cloudflare R2 Configuration
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_RESUME_KEY=resume.pdf
